---
import { siteConfig } from "../../config/site";
import BotIcon from "../ui/BotIcon.astro";
---

<nav class="nav" id="mainNav">
  <div class="nav-logo">
    <BotIcon size={32} id="nav" />
    <span>{siteConfig.name}</span>
    <span class="android-badge">for Android&trade;</span>
  </div>
  <div class="nav-right">
    {siteConfig.navLinks.map((link) => (
      <a class="nav-link" href={link.href}>{link.text}</a>
    ))}
    <a class="cta-btn" href="#download">Download App</a>
  </div>
  <button class="theme-btn" id="themeToggle" aria-label="Toggle theme">
    <svg class="sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a0a0ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
  <div class="mobile-only">
    <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
      <svg id="menuIco" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text)" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg id="closeIco" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text)" stroke-width="2" stroke-linecap="round" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a class="nav-link" href="#modes">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Modes
  </a>
  <a class="nav-link" href="#how-it-works">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    How It Works
  </a>
  <a class="nav-link" href="#why-botpilot">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    Why BotPilot
  </a>
  <div class="menu-cta">
    <a class="cta-btn" href="#download">Download App</a>
    <span class="hint">Android 10+ required</span>
  </div>
</div>

<style>
.nav{position:fixed;top:0;left:0;right:0;z-index:100;height:64px;display:flex;align-items:center;padding:0 40px;transition:all .4s;border-bottom:1px solid transparent;gap:8px}
.nav.scrolled{background:var(--bg-nav);backdrop-filter:blur(20px) saturate(1.2);border-bottom-color:var(--border)}
.nav-link{color:var(--text-m);font-size:14px;font-weight:500;transition:color .3s;letter-spacing:.3px;cursor:pointer}
.nav-link:hover{color:var(--text)}
.nav-logo{display:flex;align-items:center;gap:8px}
.nav-logo span{font-weight:800;font-size:18px;letter-spacing:-.5px;transition:color .4s}
.nav-right{display:flex;align-items:center;gap:28px;margin-left:auto}
.android-badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:6px;background:color-mix(in srgb,var(--green) 10%,transparent);font-size:9px!important;font-weight:700!important;color:var(--green);letter-spacing:1px}
.cta-btn{background:var(--green);color:#000;border:none;padding:9px 22px;border-radius:10px;font-weight:700;font-size:13px;cursor:pointer;transition:background .3s;font-family:inherit;display:inline-block;text-align:center}
.theme-btn{width:44px;height:44px;border-radius:12px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .4s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden;flex-shrink:0;-webkit-tap-highlight-color:transparent}
.theme-btn .sun,.theme-btn .moon{position:absolute;transition:all .4s cubic-bezier(.16,1,.3,1)}
body:not(.light) .theme-btn{background:#1e1e22;border:1px solid #2a2a30}
body.light .theme-btn{background:#e8e8ec;border:1px solid #d0d0d8}
body:not(.light) .sun{transform:rotate(-90deg) scale(0);opacity:0}
body:not(.light) .moon{transform:rotate(0) scale(1);opacity:1}
body.light .sun{transform:rotate(0) scale(1);opacity:1}
body.light .moon{transform:rotate(90deg) scale(0);opacity:0}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:4px;-webkit-tap-highlight-color:transparent}
.hamburger svg{stroke:var(--text)}
.mobile-only{display:none}
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;bottom:0;background:var(--menu-bg);backdrop-filter:blur(20px);z-index:99;flex-direction:column;padding:24px 24px 32px;animation:slideDown .3s ease both;overflow-y:auto;gap:10px}
.mobile-menu.open{display:flex}
.mobile-menu .nav-link{font-size:17px;font-weight:600;display:flex;align-items:center;gap:12px;padding:16px 18px;border-radius:14px;background:var(--card);border:1px solid var(--border);transition:all .3s;width:100%}
.mobile-menu .nav-link:active{transform:scale(.97)}
.mobile-menu .menu-cta{margin-top:auto;padding-top:24px;display:flex;flex-direction:column;align-items:center;gap:10px;width:100%}
.mobile-menu .cta-btn{width:100%;padding:14px;font-size:15px;border-radius:12px}
.hint{color:var(--text-d);font-size:12px;transition:color .4s}
@media(max-width:899px){.nav{padding:0 24px}.nav-right .nav-link,.nav-right .cta-btn{display:none}.hamburger{display:block}.mobile-only{display:flex;align-items:center}}
@media(max-width:639px){.nav{height:56px;padding:0 16px}.nav > .theme-btn{width:38px;height:38px;border-radius:10px}.nav > .theme-btn .sun{width:18px;height:18px}.nav > .theme-btn .moon{width:16px;height:16px}.mobile-menu{top:56px;padding:20px 16px 28px}.nav-logo span{font-size:16px}.nav-logo .android-badge{display:none}}
</style>

<script>
  document.getElementById("themeToggle")?.addEventListener("click", () => {
    document.body.classList.toggle("light");
  });

  window.addEventListener("scroll", () => {
    document.getElementById("mainNav")?.classList.toggle("scrolled", window.scrollY > 50);
  }, { passive: true });

  document.getElementById("hamburgerBtn")?.addEventListener("click", () => {
    const menu = document.getElementById("mobileMenu");
    const open = menu?.classList.toggle("open");
    const menuIco = document.getElementById("menuIco");
    const closeIco = document.getElementById("closeIco");
    if (menuIco) menuIco.style.display = open ? "none" : "";
    if (closeIco) closeIco.style.display = open ? "" : "none";
  });

  document.querySelectorAll(".mobile-menu .nav-link, .mobile-menu .cta-btn").forEach((link) => {
    link.addEventListener("click", () => {
      const menu = document.getElementById("mobileMenu");
      menu?.classList.remove("open");
      const menuIco = document.getElementById("menuIco");
      const closeIco = document.getElementById("closeIco");
      if (menuIco) menuIco.style.display = "";
      if (closeIco) closeIco.style.display = "none";
    });
  });
</script>
