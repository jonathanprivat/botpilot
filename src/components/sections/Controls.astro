        <div class="chip"><span class="chip-label">Fast</span><span class="chip-range">1-2.5s</span></div>
        <div class="chip active"><span class="chip-label">Normal</span><span class="chip-range">2-4s</span></div>
        <div class="chip"><span class="chip-label">Slow</span><span class="chip-range">4-7s</span></div>
        <div class="chip"><span class="chip-label">Super Slow</span><span class="chip-range">7-12s</span></div>
      </div>
    </div>
  </div>
</section>

