---
import BotIcon from "../ui/BotIcon.astro";
import PlayBadge from "../ui/PlayBadge.astro";
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-orb hero-orb1"></div>
    <div class="hero-orb hero-orb2"></div>
    <div class="hero-grid"></div>
  </div>
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="badges">
        <div class="badge-pill badge-green"><div class="pulse-dot"></div> ON-DEVICE</div>
        <div class="badge-pill badge-muted">ANDROID&trade; EXCLUSIVE</div>
      </div>
      <h1>Hands-free Instagram<br /><span class="grad-text">engagement.</span></h1>
      <p class="sub">
        BotPilot runs on your phone, not in the cloud. It watches stories, likes posts, drops GIF
        comments, reacts with emojis, and likes other people's comments &mdash; all on your real
        device. No passwords shared. No data leaves your phone.
      </p>
      <div class="play-wrap">
        <PlayBadge />
        <span class="hint">Android&trade; 10+ required &middot; No root needed</span>
      </div>
    </div>
    <div class="hero-phone">
      <div style="position:relative">
        <div class="phone-glow"></div>
        <div class="phone">
          <div class="phone-status">
            <span>9:41</span>
            <div style="display:flex;gap:4px;align-items:center">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--text)" opacity=".4"><path d="M2 22h20L12 2z" /></svg>
              <svg width="14" height="12" viewBox="0 0 24 16" fill="var(--text)" opacity=".4"><rect x="0" y="0" width="22" height="14" rx="3" stroke="var(--text)" stroke-width="1.5" fill="none" /><rect x="3" y="3" width="14" height="8" rx="1" fill="var(--text)" /><rect x="23" y="4" width="2" height="6" rx="1" fill="var(--text)" /></svg>
            </div>
          </div>
          <div class="phone-notch"></div>
          <div class="phone-content">
            <BotIcon size={100} id="phone" />
            <div style="width:100%;display:flex;flex-direction:column;gap:6px;padding:0 2px">
              <div class="activity" style="animation:fadeUp .5s ease both .6s">
                <div class="activity-dot" style="background:#a78bfa;box-shadow:0 0 8px #a78bfa60"></div>
                <div style="flex:1;min-width:0"><span class="activity-label" style="color:#a78bfa">STORY</span><div class="activity-text">Watched @foodie.nyc's story</div></div>
                <span class="activity-time">2s</span>
              </div>
              <div class="activity" style="animation:fadeUp .5s ease both .8s">
                <div class="activity-dot" style="background:var(--green);box-shadow:0 0 8px color-mix(in srgb,var(--green) 38%,transparent)"></div>
                <div style="flex:1;min-width:0"><span class="activity-label" style="color:var(--green)">GIF REACT</span><div class="activity-text">GIF react on @travel.co's post</div></div>
                <span class="activity-time">5s</span>
              </div>
              <div class="activity" style="animation:fadeUp .5s ease both 1s">
                <div class="activity-dot" style="background:#f59e0b;box-shadow:0 0 8px #f59e0b60"></div>
                <div style="flex:1;min-width:0"><span class="activity-label" style="color:#f59e0b">EMOJI</span><div class="activity-text">🔥 reacted to @fitness.daily</div></div>
                <span class="activity-time">8s</span>
              </div>
              <div class="activity desktop-only" style="animation:fadeUp .5s ease both 1.2s">
                <div class="activity-dot" style="background:#6366f1;box-shadow:0 0 8px #6366f160"></div>
                <div style="flex:1;min-width:0"><span class="activity-label" style="color:#6366f1">COMMENT LIKE</span><div class="activity-text">Liked 3 comments on #miami</div></div>
                <span class="activity-time">12s</span>
              </div>
            </div>
          </div>
          <div class="phone-bar"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;padding:120px 40px 80px}
.hero-bg{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.hero-orb{position:absolute;border-radius:50%;filter:blur(60px)}
.hero-orb1{top:15%;left:5%;width:400px;height:400px;background:radial-gradient(circle,var(--orb1),transparent 70%);animation:float1 20s ease-in-out infinite}
.hero-orb2{bottom:20%;right:5%;width:350px;height:350px;background:radial-gradient(circle,var(--orb2),transparent 70%);animation:float2 18s ease-in-out infinite;filter:blur(50px)}
.hero-grid{position:absolute;inset:0;opacity:.03;background-image:linear-gradient(var(--grid) 1px,transparent 1px),linear-gradient(90deg,var(--grid) 1px,transparent 1px);background-size:60px 60px}
.hero-inner{max-width:1100px;width:100%;display:flex;align-items:center;gap:80px;position:relative;z-index:1}
.hero-copy{flex:1 1 480px;min-width:0;animation:fadeUp .8s ease both}
.hero-phone{flex:0 0 auto;position:relative;animation:fadeUp .8s ease both .3s;display:flex;flex-direction:column;align-items:center}
.badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px}
.badge-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:100px;font-size:11px;font-weight:600;letter-spacing:1px;transition:all .4s}
.badge-green{border:1px solid color-mix(in srgb,var(--green) 15%,transparent);background:color-mix(in srgb,var(--green) 5%,transparent);color:var(--green)}
.badge-muted{border:1px solid var(--border);background:var(--card);color:var(--text-m)}
.pulse-dot{width:6px;height:6px;border-radius:50%;background:var(--green);position:relative}
.pulse-dot::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:1.5px solid color-mix(in srgb,var(--green) 25%,transparent);animation:pulseRing 2s ease infinite}
.hero-copy h1{font-size:60px;font-weight:900;line-height:1.08;letter-spacing:-2px;margin-bottom:24px;transition:color .4s}
.hero-copy .sub{font-size:18px;color:var(--text-m);line-height:1.65;max-width:480px;margin-bottom:40px;transition:color .4s}
.grad-text{background:linear-gradient(135deg,var(--green),var(--green-lt));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
.play-wrap{display:flex;flex-direction:column;gap:12px}
.hint{color:var(--text-d);font-size:12px;transition:color .4s}
.phone{width:300px;height:600px;border-radius:40px;border:3px solid var(--phone-bz);background:var(--phone-bg);position:relative;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.35),inset 0 0 0 1px var(--phone-bz);transition:background .4s,border-color .4s}
.phone-status{height:36px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:relative;z-index:2}
.phone-status span{font-size:11px;font-weight:600;color:var(--text);opacity:.5;transition:color .4s}
.phone-notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:100px;height:24px;background:var(--phone-bz);border-radius:0 0 16px 16px;z-index:3;transition:background .4s}
.phone-content{padding:12px;height:calc(100% - 36px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px}
.phone-bar{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:100px;height:4px;border-radius:4px;background:var(--text);opacity:.15}
.phone-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,var(--glow),transparent 70%);filter:blur(40px)}
.activity{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--card);border-radius:10px;border:1px solid var(--border);width:100%;transition:background .4s,border-color .4s}
.activity-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.activity-label{font-size:8px;font-weight:700;letter-spacing:1.5px}
.activity-text{color:var(--text);font-size:10px;margin-top:1px;opacity:.85;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:color .4s}
.activity-time{color:var(--text-d);font-size:9px;flex-shrink:0;transition:color .4s}
.desktop-only{display:flex}
@media(max-width:899px){.hero-inner{flex-direction:column;text-align:center;gap:48px}.badges{justify-content:center}.hero-copy .sub{margin-left:auto;margin-right:auto}.play-wrap{align-items:center}}
@media(max-width:639px){.hero{padding:90px 20px 50px;min-height:auto}.hero-copy h1{font-size:32px;letter-spacing:-1px}.hero-copy .sub{font-size:15px}.phone{width:220px;height:440px;border-radius:28px}.phone-status{height:28px;padding:0 14px}.phone-status span{font-size:9px}.phone-notch{width:80px;height:18px}.phone-content{padding:8px;gap:6px}.phone-bar{width:80px;bottom:6px}.desktop-only{display:none}.hero-orb1{width:200px;height:200px}.hero-orb2{width:180px;height:180px}.hero-grid{background-size:40px 40px}}
@media(max-width:420px){.hero-copy h1{font-size:28px}.phone{width:200px;height:400px;border-radius:24px}.phone-content{gap:5px}.activity{padding:8px 10px;gap:8px}.activity-text{font-size:9px}.activity-label{font-size:7px}.activity-time{font-size:8px}}
</style>
