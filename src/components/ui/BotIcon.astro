---
interface Props {
  size?: number;
  id?: string;
}
const { size = 32, id = "icon" } = Astro.props;
---

<svg viewBox="0 0 256 256" width={size} height={size} style="overflow:visible;display:block">
  <defs>
    <radialGradient id={`bgG-${id}`} cx="50%" cy="40%" r="60%">
      <stop offset="0%" stop-color="#1a1a1e" />
      <stop offset="100%" stop-color="#0e0e10" />
    </radialGradient>
  </defs>
  <rect x="8" y="8" width="240" height="240" rx="52" ry="52" fill={`url(#bgG-${id})`} />
  <g class="bf">
    <g class="bh">
      <ellipse cx="128" cy="112" rx="72" ry="56" fill="#fff" />
      <rect x="78" y="84" width="100" height="56" rx="28" ry="28" fill="#111" />
    </g>
    <g class="be">
      <g class="bl"><circle cx="104" cy="112" r="8" fill="#fff" /></g>
      <g class="br"><circle cx="152" cy="112" r="8" fill="#fff" /></g>
    </g>
    <path class="bm" d="M100,178 L112,164 L124,178 L136,164 L148,178" fill="none" stroke="#2DD4A0" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
  </g>
</svg>
